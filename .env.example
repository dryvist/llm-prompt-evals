# Copy to .env and fill in real values. NEVER commit .env — it is gitignored.
# The eval harness reads every credential and endpoint from the environment.

# Cloud providers (systems under test + the llm-rubric grader).
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Local fabric: an OpenAI-compatible endpoint supplied by your environment.
# Never commit a real URL — the value stays in your .env or the CI runner env.
LOCAL_FABRIC_BASE_URL=
LOCAL_FABRIC_MODEL=
